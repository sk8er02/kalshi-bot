# ============================================================
# Kalshi Trading Bot - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git
# ============================================================

# --- Kalshi API Credentials ---
# Get these from https://kalshi.com/profile/api-keys
KALSHI_API_KEY_ID=your_api_key_id_here
# Local: /path/to/your/private_key.pem
# Docker: /app/keys/private_key.pem (mounted automatically)
KALSHI_PRIVATE_KEY_PATH=/app/keys/private_key.pem

# API base URL
# Production: https://api.elections.kalshi.com/trade-api/v2
# Demo:       https://demo-api.kalshi.co/trade-api/v2
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# --- OpenRouter API ---
# Get your key from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# --- Risk Controls (all values in cents) ---
MAX_TRADE_COST_CENTS=500        # $5 max per trade
MIN_TRADE_COST_CENTS=100        # $1 min per trade
MAX_DAILY_SPEND_CENTS=5000      # $50 daily hard limit
DAILY_LOSS_KILL_SWITCH_CENTS=2000  # $20 loss trips kill switch

# --- Bot Behavior ---
# Set to "true" to simulate without placing real orders
DRY_RUN=true

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Telegram Notifications (optional) ---
# See README for setup instructions
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
